.container {
  padding-bottom: 120rpx;
}

/* 空购物车 */
.empty-cart {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-top: 200rpx;
}

.empty-icon {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 32rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
  margin-bottom: 32rpx;
}

.go-shopping {
  padding: 16rpx 48rpx;
  background: #4A90D9;
  color: #fff;
  border-radius: 40rpx;
  font-size: 28rpx;
}

/* 购物车列表 */
.cart-list {
  padding: 16rpx;
}

.cart-item {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
}

.cart-item-check {
  margin-right: 16rpx;
}

.checkbox {
  width: 44rpx;
  height: 44rpx;
  border: 2rpx solid #ddd;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: #fff;
}

.checkbox.checked {
  background: #4A90D9;
  border-color: #4A90D9;
}

.cart-item-image {
  width: 160rpx;
  height: 160rpx;
  border-radius: 8rpx;
  flex-shrink: 0;
}

.cart-item-info {
  flex: 1;
  margin-left: 20rpx;
}

.cart-item-name {
  font-size: 28rpx;
  font-weight: bold;
  margin-bottom: 8rpx;
}

.cart-item-spec {
  font-size: 22rpx;
  color: #999;
  background: #f5f5f5;
  padding: 4rpx 12rpx;
  border-radius: 4rpx;
  display: inline-block;
  margin-bottom: 12rpx;
}

.cart-item-bottom {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.cart-item-price {
  font-size: 32rpx;
  color: #e74c3c;
  font-weight: bold;
}

.cart-item-delete {
  font-size: 24rpx;
  color: #999;
  padding: 8rpx 16rpx;
  margin-left: 12rpx;
}

/* 数量控制 */
.quantity-control {
  display: flex;
  align-items: center;
}

.qty-btn {
  width: 52rpx;
  height: 52rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 2rpx solid #ddd;
  font-size: 30rpx;
  color: #333;
}

.qty-btn.minus {
  border-radius: 8rpx 0 0 8rpx;
}

.qty-btn.plus {
  border-radius: 0 8rpx 8rpx 0;
}

.qty-value {
  width: 64rpx;
  height: 52rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-top: 2rpx solid #ddd;
  border-bottom: 2rpx solid #ddd;
  font-size: 26rpx;
}

/* 底部结算栏 */
.settle-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  align-items: center;
  padding: 16rpx 24rpx;
  background: #fff;
  border-top: 1rpx solid #eee;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
}

.select-all {
  display: flex;
  align-items: center;
  gap: 12rpx;
  font-size: 26rpx;
  color: #666;
}

.settle-info {
  flex: 1;
  text-align: right;
  margin-right: 20rpx;
}

.settle-total {
  font-size: 26rpx;
  color: #333;
}

.settle-price {
  font-size: 34rpx;
  color: #e74c3c;
  font-weight: bold;
}

.settle-btn {
  padding: 18rpx 40rpx;
  background: #ccc;
  color: #fff;
  border-radius: 40rpx;
  font-size: 28rpx;
}

.settle-btn.active {
  background: #4A90D9;
}