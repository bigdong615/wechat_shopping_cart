<view class="container">
  <view wx:if="{{addressList.length === 0}}" class="empty">
    <text class="empty-text">暂无收货地址</text>
  </view>

  <view class="address-list">
    <view class="address-card" wx:for="{{addressList}}" wx:key="id">
      <view class="address-content" data-id="{{item.id}}" bindtap="onSelect">
        <view class="address-header">
          <text class="address-name">{{item.name}}</text>
          <text class="address-phone">{{item.phone}}</text>
          <view wx:if="{{item.isDefault}}" class="default-tag">默认</view>
        </view>
        <view class="address-detail">{{item.province}} {{item.city}} {{item.district}} {{item.detail}}</view>
      </view>
      <view class="address-actions">
        <view class="action-btn" data-id="{{item.id}}" bindtap="onEdit">编辑</view>
        <view class="action-btn delete" data-id="{{item.id}}" bindtap="onDelete">删除</view>
      </view>
    </view>
  </view>

  <view class="add-btn" bindtap="onAdd">+ 新增收货地址</view>
</view>