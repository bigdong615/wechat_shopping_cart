.container {
  padding: 16rpx;
}

.form {
  background: #fff;
  border-radius: 16rpx;
  padding: 8rpx 24rpx;
}

.form-item {
  display: flex;
  align-items: center;
  padding: 28rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.form-item:last-child {
  border-bottom: none;
}

.label {
  width: 160rpx;
  font-size: 28rpx;
  color: #333;
  flex-shrink: 0;
  font-weight: 500;
}

.input {
  flex: 1;
  font-size: 28rpx;
}

.picker-text {
  flex: 1;
  font-size: 28rpx;
  color: #333;
}

.picker-text.placeholder {
  color: #bbb;
}

.form-arrow {
  font-size: 32rpx;
  color: #ccc;
  margin-left: 8rpx;
}

.switch-item {
  justify-content: space-between;
}

.save-btn {
  margin-top: 40rpx;
  padding: 24rpx;
  background: linear-gradient(135deg, #4A90D9, #5fa8e8);
  color: #fff;
  text-align: center;
  border-radius: 48rpx;
  font-size: 32rpx;
  font-weight: bold;
}