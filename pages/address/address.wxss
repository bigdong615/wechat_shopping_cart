.container {
  padding: 16rpx;
  padding-bottom: 140rpx;
}

.empty {
  display: flex;
  justify-content: center;
  padding: 100rpx 0;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}

.address-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
}

.address-content {
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.address-header {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 8rpx;
}

.address-name {
  font-size: 30rpx;
  font-weight: bold;
}

.address-phone {
  font-size: 26rpx;
  color: #666;
}

.default-tag {
  font-size: 20rpx;
  color: #4A90D9;
  border: 1rpx solid #4A90D9;
  padding: 2rpx 10rpx;
  border-radius: 4rpx;
}

.address-detail {
  font-size: 26rpx;
  color: #666;
  line-height: 1.5;
}

.address-actions {
  display: flex;
  justify-content: flex-end;
  gap: 24rpx;
  padding-top: 16rpx;
}

.action-btn {
  font-size: 24rpx;
  color: #666;
  padding: 8rpx 16rpx;
}

.action-btn.delete {
  color: #e74c3c;
}

.add-btn {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 24rpx;
  background: #4A90D9;
  color: #fff;
  text-align: center;
  font-size: 30rpx;
  font-weight: bold;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
}