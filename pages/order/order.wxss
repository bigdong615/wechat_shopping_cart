.container {
  background: #f5f5f5;
  min-height: 100vh;
}

.tab-bar {
  display: flex;
  background: #fff;
  border-bottom: 1rpx solid #eee;
}

.tab {
  flex: 1;
  text-align: center;
  padding: 24rpx 0;
  font-size: 28rpx;
  color: #666;
  position: relative;
}

.tab.active {
  color: #4A90D9;
  font-weight: bold;
}

.tab.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 60rpx;
  height: 4rpx;
  background: #4A90D9;
  border-radius: 2rpx;
}

.empty {
  display: flex;
  justify-content: center;
  padding: 100rpx 0;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}

.order-list {
  padding: 16rpx;
}

.order-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
}

.order-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.order-no {
  font-size: 24rpx;
  color: #999;
}

.order-status {
  font-size: 24rpx;
  font-weight: bold;
}

.order-status.paid {
  color: #f5a623;
}

.order-status.shipped {
  color: #4A90D9;
}

.order-status.completed {
  color: #27ae60;
}

.order-items {
  margin-bottom: 16rpx;
}

.order-item {
  display: flex;
  align-items: center;
  padding: 12rpx 0;
}

.item-image {
  width: 100rpx;
  height: 100rpx;
  border-radius: 8rpx;
  flex-shrink: 0;
}

.item-info {
  flex: 1;
  margin-left: 16rpx;
}

.item-name {
  font-size: 26rpx;
  color: #333;
}

.item-spec {
  font-size: 22rpx;
  color: #999;
  margin-top: 4rpx;
}

.item-right {
  text-align: right;
}

.item-price {
  font-size: 26rpx;
  color: #333;
}

.item-qty {
  font-size: 22rpx;
  color: #999;
  display: block;
  margin-top: 4rpx;
}

.order-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 16rpx;
  border-top: 1rpx solid #f0f0f0;
}

.order-time {
  font-size: 22rpx;
  color: #999;
}

.order-total {
  font-size: 24rpx;
  color: #333;
}

.total-amount {
  color: #e74c3c;
  font-weight: bold;
  font-size: 28rpx;
}

.order-actions {
  display: flex;
  justify-content: flex-end;
  gap: 16rpx;
  padding-top: 16rpx;
}

.action-btn {
  padding: 12rpx 32rpx;
  border: 2rpx solid #ddd;
  border-radius: 32rpx;
  font-size: 24rpx;
  color: #666;
}

.action-btn.primary {
  border-color: #4A90D9;
  color: #4A90D9;
}