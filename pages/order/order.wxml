<view class="container">
  <!-- 订单状态筛选 -->
  <view class="tab-bar">
    <view class="tab {{activeTab === 'all' ? 'active' : ''}}" data-tab="all" bindtap="switchTab">全部</view>
    <view class="tab {{activeTab === 'paid' ? 'active' : ''}}" data-tab="paid" bindtap="switchTab">待发货</view>
    <view class="tab {{activeTab === 'shipped' ? 'active' : ''}}" data-tab="shipped" bindtap="switchTab">待收货</view>
    <view class="tab {{activeTab === 'completed' ? 'active' : ''}}" data-tab="completed" bindtap="switchTab">已完成</view>
  </view>

  <!-- 订单列表 -->
  <view wx:if="{{orders.length === 0}}" class="empty">
    <text class="empty-text">暂无订单</text>
  </view>

  <view class="order-list">
    <view class="order-card" wx:for="{{orders}}" wx:key="id" data-id="{{item.id}}" bindtap="goDetail">
      <view class="order-header">
        <text class="order-no">订单号: {{item.orderNo}}</text>
        <text class="order-status {{item.status}}">{{item.statusText}}</text>
      </view>
      <view class="order-items">
        <view class="order-item" wx:for="{{item.items}}" wx:for-item="product" wx:key="key">
          <image class="item-image" src="{{product.image}}" mode="aspectFill" />
          <view class="item-info">
            <view class="item-name">{{product.name}}</view>
            <view wx:if="{{product.specName}}" class="item-spec">{{product.specName}}</view>
          </view>
          <view class="item-right">
            <text class="item-price">¥{{product.priceText}}</text>
            <text class="item-qty">×{{product.quantity}}</text>
          </view>
        </view>
      </view>
      <view class="order-footer">
        <text class="order-time">{{item.createTime}}</text>
        <view class="order-total">
          <text>共{{item.totalCount}}件 合计: </text>
          <text class="total-amount">¥{{item.totalPriceText}}</text>
        </view>
      </view>
      <view class="order-actions">
        <view wx:if="{{item.status === 'paid'}}" class="action-btn" data-id="{{item.id}}" catchtap="onConfirmShip">模拟发货</view>
        <view wx:if="{{item.status === 'shipped'}}" class="action-btn primary" data-id="{{item.id}}" catchtap="onConfirmReceive">确认收货</view>
      </view>
    </view>
  </view>
</view>