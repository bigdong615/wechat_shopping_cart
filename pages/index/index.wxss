/* 搜索栏 */
.search-bar {
  display: flex;
  align-items: center;
  padding: 16rpx 24rpx;
  background: #fff;
  border-bottom: 1rpx solid #eee;
}

.search-input-wrap {
  flex: 1;
  display: flex;
  align-items: center;
  background: #f5f5f5;
  border-radius: 32rpx;
  padding: 12rpx 24rpx;
}

.search-input {
  flex: 1;
  margin-left: 12rpx;
  font-size: 28rpx;
}

.search-btn {
  margin-left: 20rpx;
  font-size: 28rpx;
  color: #333;
}

/* 主体内容 */
.main-content {
  display: flex;
  flex: 1;
  height: calc(100vh - 100rpx - 260rpx - env(safe-area-inset-bottom));
}

/* 左侧分类 */
.category-sidebar {
  width: 180rpx;
  background: #f8f8f8;
  height: 100%;
}

.category-group-title {
  padding: 24rpx 16rpx;
  font-size: 26rpx;
  color: #333;
  text-align: center;
  border-left: 6rpx solid transparent;
  background: #f8f8f8;
}

.category-group-title.active {
  background: #fff;
  color: #4A90D9;
  font-weight: bold;
  border-left-color: #4A90D9;
}

.category-item {
  padding: 20rpx 16rpx;
  font-size: 24rpx;
  color: #666;
  text-align: center;
  background: #f0f0f0;
}

.category-item.active {
  color: #4A90D9;
  background: #e8f0fe;
  font-weight: bold;
}

/* 右侧商品列表 */
.product-list {
  flex: 1;
  height: 100%;
  background: #fff;
}

.product-group-title {
  padding: 20rpx 24rpx;
  font-size: 26rpx;
  color: #999;
  background: #f5f5f5;
  border-bottom: 1rpx solid #eee;
}

.product-card {
  display: flex;
  padding: 24rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.product-image {
  width: 200rpx;
  height: 200rpx;
  border-radius: 8rpx;
  flex-shrink: 0;
}

.product-info {
  flex: 1;
  margin-left: 20rpx;
  display: flex;
  flex-direction: column;
  position: relative;
}

.product-name {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
}

.product-meta {
  font-size: 22rpx;
  color: #999;
  margin-bottom: 12rpx;
}

.meta-space {
  margin: 0 16rpx;
}

.product-price {
  font-size: 36rpx;
  color: #e74c3c;
  font-weight: bold;
  margin-bottom: 12rpx;
}

.product-actions {
  position: absolute;
  right: 0;
  bottom: 0;
}

/* 选规格按钮 */
.spec-btn {
  padding: 10rpx 28rpx;
  border: 2rpx solid #4A90D9;
  color: #4A90D9;
  font-size: 24rpx;
  border-radius: 8rpx;
  text-align: center;
}

/* 售罄按钮 */
.soldout-btn {
  padding: 10rpx 28rpx;
  border: 2rpx solid #ccc;
  color: #999;
  font-size: 24rpx;
  border-radius: 8rpx;
  text-align: center;
}

/* 数量控制 */
.quantity-control {
  display: flex;
  align-items: center;
}

.qty-btn {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 2rpx solid #ddd;
  font-size: 32rpx;
  color: #333;
  background: #fff;
}

.qty-btn.minus {
  border-radius: 8rpx 0 0 8rpx;
}

.qty-btn.plus {
  border-radius: 0 8rpx 8rpx 0;
}

.qty-value {
  width: 72rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-top: 2rpx solid #ddd;
  border-bottom: 2rpx solid #ddd;
  font-size: 28rpx;
  color: #333;
}

/* 底部购物车栏 */
.cart-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  z-index: 100;
  padding-bottom: env(safe-area-inset-bottom);
  background: #fff;
}

.address-tip {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 12rpx 24rpx;
  background: #fffbe6;
  font-size: 24rpx;
  color: #666;
}

.address-tip .arrow {
  margin-left: 8rpx;
  font-size: 28rpx;
}

.cart-bar-content {
  display: flex;
  align-items: center;
  padding: 16rpx 24rpx;
  background: rgba(60, 60, 60, 0.95);
  border-radius: 48rpx 48rpx 0 0;
}

.cart-icon-wrap {
  position: relative;
  width: 80rpx;
  height: 80rpx;
  background: #4A4A4A;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: -30rpx;
}

.cart-icon {
  width: 48rpx;
  height: 48rpx;
}

.cart-badge {
  position: absolute;
  top: -8rpx;
  right: -8rpx;
  background: #e74c3c;
  color: #fff;
  font-size: 20rpx;
  min-width: 32rpx;
  height: 32rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 6rpx;
}

.cart-summary {
  flex: 1;
  margin-left: 20rpx;
}

.cart-total {
  color: #fff;
  font-size: 28rpx;
  font-weight: bold;
}

.cart-delivery {
  color: #aaa;
  font-size: 22rpx;
  margin-top: 4rpx;
}

.checkout-btn {
  padding: 20rpx 40rpx;
  background: #666;
  color: #999;
  border-radius: 40rpx;
  font-size: 28rpx;
}

.checkout-btn.active {
  background: #f5c518;
  color: #333;
}

/* 规格选择弹窗 */
.spec-modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 200;
  display: flex;
  align-items: flex-end;
}

.spec-modal {
  width: 100%;
  background: #fff;
  border-radius: 24rpx 24rpx 0 0;
  padding: 32rpx;
  padding-bottom: calc(32rpx + env(safe-area-inset-bottom));
}

.spec-modal-header {
  display: flex;
  align-items: flex-start;
  margin-bottom: 32rpx;
}

.spec-product-image {
  width: 160rpx;
  height: 160rpx;
  border-radius: 8rpx;
}

.spec-product-info {
  flex: 1;
  margin-left: 20rpx;
}

.spec-product-name {
  font-size: 30rpx;
  font-weight: bold;
  margin-bottom: 16rpx;
}

.spec-product-price {
  font-size: 36rpx;
  color: #e74c3c;
  font-weight: bold;
}

.spec-close {
  font-size: 48rpx;
  color: #999;
  padding: 0 16rpx;
}

.spec-list {
  margin-bottom: 32rpx;
}

.spec-label {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 16rpx;
  font-weight: bold;
}

.spec-options {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.spec-option {
  padding: 16rpx 32rpx;
  border: 2rpx solid #ddd;
  border-radius: 8rpx;
  font-size: 26rpx;
  color: #666;
}

.spec-option.active {
  border-color: #4A90D9;
  color: #4A90D9;
  background: #e8f0fe;
}

.spec-quantity-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 32rpx;
  font-size: 28rpx;
}

.spec-confirm-btn {
  width: 100%;
  padding: 24rpx 0;
  background: #4A90D9;
  color: #fff;
  text-align: center;
  border-radius: 48rpx;
  font-size: 32rpx;
  font-weight: bold;
}