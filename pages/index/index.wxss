/* 页面容器 */
page {
  height: 100vh;
  overflow: hidden;
}

.container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  overflow: hidden;
}

/* 搜索栏 */
.search-bar {
  display: flex;
  align-items: center;
  padding: 16rpx 24rpx;
  background: linear-gradient(135deg, #4A90D9, #5fa8e8);
}

.search-input-wrap {
  flex: 1;
  display: flex;
  align-items: center;
  background: rgba(255,255,255,0.95);
  border-radius: 32rpx;
  padding: 12rpx 24rpx;
}

.search-input {
  flex: 1;
  margin-left: 12rpx;
  font-size: 28rpx;
}

.search-clear {
  width: 40rpx;
  height: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #ccc;
  color: #fff;
  border-radius: 50%;
  font-size: 24rpx;
}

.search-btn {
  margin-left: 20rpx;
  font-size: 28rpx;
  color: #fff;
  font-weight: bold;
}

/* 主体内容 */
.main-content {
  display: flex;
  flex: 1;
  overflow: hidden;
}

/* 左侧分类 */
.category-sidebar {
  width: 180rpx;
  background: #f5f5f5;
  height: 100%;
}

.category-group-title {
  padding: 26rpx 16rpx;
  font-size: 26rpx;
  color: #333;
  text-align: center;
  border-left: 6rpx solid transparent;
  background: #f5f5f5;
  transition: all 0.2s;
}

.category-group-title.active {
  background: #fff;
  color: #4A90D9;
  font-weight: bold;
  border-left-color: #4A90D9;
}

.category-item {
  padding: 22rpx 16rpx;
  font-size: 24rpx;
  color: #666;
  text-align: center;
  background: #eee;
}

.category-item.active {
  color: #4A90D9;
  background: #e8f0fe;
  font-weight: bold;
}

/* 右侧商品列表 */
.product-list {
  flex: 1;
  height: 100%;
  background: #fff;
}

/* 轮播banner */
.banner-wrap {
  padding: 16rpx 16rpx 0;
}

.banner-swiper {
  height: 220rpx;
  border-radius: 16rpx;
  overflow: hidden;
}

.banner-image {
  width: 100%;
  height: 100%;
  border-radius: 16rpx;
}

.banner-title {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 16rpx 24rpx;
  background: linear-gradient(transparent, rgba(0,0,0,0.5));
  color: #fff;
  font-size: 26rpx;
  font-weight: bold;
  border-radius: 0 0 16rpx 16rpx;
}

.product-group-title {
  padding: 20rpx 24rpx;
  font-size: 26rpx;
  color: #666;
  background: #f8f8f8;
  border-bottom: 1rpx solid #eee;
  font-weight: 500;
}

.product-card {
  display: flex;
  padding: 24rpx 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.product-image {
  width: 180rpx;
  height: 180rpx;
  border-radius: 12rpx;
  flex-shrink: 0;
  background: #f5f5f5;
}

.product-info {
  flex: 1;
  margin-left: 20rpx;
  display: flex;
  flex-direction: column;
  position: relative;
  min-height: 180rpx;
}

.product-name {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 6rpx;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

/* 标签 */
.product-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-bottom: 6rpx;
}

.product-tag {
  font-size: 20rpx;
  color: #ff6b35;
  background: #fff5f0;
  padding: 2rpx 10rpx;
  border-radius: 4rpx;
  border: 1rpx solid #ffddcc;
}

.product-meta {
  font-size: 22rpx;
  color: #999;
  margin-bottom: 8rpx;
}

.meta-dot {
  margin: 0 8rpx;
}

.product-price-row {
  display: flex;
  align-items: baseline;
  gap: 12rpx;
  margin-bottom: 8rpx;
}

.product-price {
  font-size: 34rpx;
  color: #e74c3c;
  font-weight: bold;
}

.product-price text {
  font-size: 22rpx;
  font-weight: normal;
}

.product-original-price {
  font-size: 22rpx;
  color: #ccc;
  text-decoration: line-through;
}

.product-actions {
  position: absolute;
  right: 0;
  bottom: 0;
}

/* 选规格按钮 */
.spec-btn {
  padding: 10rpx 24rpx;
  border: 2rpx solid #4A90D9;
  color: #4A90D9;
  font-size: 22rpx;
  border-radius: 24rpx;
  text-align: center;
  background: #f0f6ff;
}

/* 售罄按钮 */
.soldout-btn {
  padding: 10rpx 24rpx;
  border: 2rpx solid #eee;
  color: #bbb;
  font-size: 22rpx;
  border-radius: 24rpx;
  text-align: center;
  background: #fafafa;
}

/* 数量控制 */
.quantity-control {
  display: flex;
  align-items: center;
}

.qty-btn {
  width: 52rpx;
  height: 52rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  color: #333;
  background: #fff;
}

.qty-btn.minus {
  border: 2rpx solid #ddd;
  border-radius: 50%;
  color: #999;
}

.qty-btn.plus {
  background: #4A90D9;
  color: #fff;
  border-radius: 50%;
  font-weight: bold;
}

.qty-value {
  width: 56rpx;
  height: 52rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: #333;
  font-weight: bold;
}

/* 底部购物车栏 */
.cart-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  z-index: 100;
  padding-bottom: env(safe-area-inset-bottom);
  background: #fff;
  box-shadow: 0 -4rpx 20rpx rgba(0,0,0,0.08);
}

.address-tip {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 10rpx 24rpx;
  background: #fffbe6;
  font-size: 24rpx;
  color: #666;
}

.address-icon {
  margin-right: 6rpx;
  font-size: 26rpx;
}

.no-address-text {
  color: #ff9800;
}

.address-tip .arrow {
  margin-left: 8rpx;
  font-size: 28rpx;
  color: #999;
}

.cart-bar-content {
  display: flex;
  align-items: center;
  padding: 12rpx 24rpx;
  background: #2d2d2d;
}

.cart-icon-wrap {
  position: relative;
  width: 88rpx;
  height: 88rpx;
  background: #3d3d3d;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: -30rpx;
  border: 6rpx solid #2d2d2d;
}

.cart-icon {
  width: 48rpx;
  height: 48rpx;
}

.cart-badge {
  position: absolute;
  top: -6rpx;
  right: -6rpx;
  background: #e74c3c;
  color: #fff;
  font-size: 20rpx;
  min-width: 32rpx;
  height: 32rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 6rpx;
  font-weight: bold;
}

.cart-summary {
  flex: 1;
  margin-left: 20rpx;
}

.cart-total {
  color: #fff;
  font-size: 32rpx;
  font-weight: bold;
}

.cart-empty-text {
  font-size: 26rpx;
  color: #888;
  font-weight: normal;
}

.cart-count {
  color: #aaa;
  font-size: 22rpx;
  margin-top: 2rpx;
}

.cart-delivery {
  color: #aaa;
  font-size: 22rpx;
  margin-top: 2rpx;
}

.checkout-btn {
  padding: 18rpx 36rpx;
  background: #555;
  color: #888;
  border-radius: 40rpx;
  font-size: 28rpx;
  font-weight: bold;
}

.checkout-btn.active {
  background: linear-gradient(135deg, #f5c518, #ffda44);
  color: #333;
}

/* 规格选择弹窗 */
.spec-modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 200;
  display: flex;
  align-items: flex-end;
}

.spec-modal {
  width: 100%;
  background: #fff;
  border-radius: 24rpx 24rpx 0 0;
  padding: 32rpx;
  padding-bottom: calc(32rpx + env(safe-area-inset-bottom));
  animation: slideUp 0.3s ease;
}

@keyframes slideUp {
  from { transform: translateY(100%); }
  to { transform: translateY(0); }
}

.spec-modal-header {
  display: flex;
  align-items: flex-start;
  margin-bottom: 32rpx;
}

.spec-product-image {
  width: 160rpx;
  height: 160rpx;
  border-radius: 12rpx;
}

.spec-product-info {
  flex: 1;
  margin-left: 20rpx;
}

.spec-product-name {
  font-size: 30rpx;
  font-weight: bold;
  margin-bottom: 16rpx;
}

.spec-product-price {
  font-size: 36rpx;
  color: #e74c3c;
  font-weight: bold;
}

.spec-close {
  font-size: 48rpx;
  color: #999;
  padding: 0 16rpx;
  line-height: 1;
}

.spec-list {
  margin-bottom: 32rpx;
}

.spec-label {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 16rpx;
  font-weight: bold;
}

.spec-options {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.spec-option {
  padding: 16rpx 32rpx;
  border: 2rpx solid #eee;
  border-radius: 32rpx;
  font-size: 26rpx;
  color: #666;
  transition: all 0.2s;
}

.spec-option.active {
  border-color: #4A90D9;
  color: #4A90D9;
  background: #e8f0fe;
}

.spec-quantity-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 32rpx;
  font-size: 28rpx;
}

.spec-confirm-btn {
  width: 100%;
  padding: 24rpx 0;
  background: linear-gradient(135deg, #4A90D9, #5fa8e8);
  color: #fff;
  text-align: center;
  border-radius: 48rpx;
  font-size: 32rpx;
  font-weight: bold;
}