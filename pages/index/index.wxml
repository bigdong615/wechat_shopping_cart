<view class="container">
  <!-- 搜索栏 -->
  <view class="search-bar">
    <view class="search-input-wrap">
      <icon type="search" size="14" color="#999" />
      <input class="search-input" placeholder="搜索海鲜、肉类..." value="{{searchKeyword}}" bindinput="onSearchInput" bindconfirm="onSearchConfirm" confirm-type="search" />
      <view wx:if="{{searchKeyword}}" class="search-clear" bindtap="onClearSearch">×</view>
    </view>
    <view class="search-btn" bindtap="onSearch">搜索</view>
  </view>

  <!-- 主体内容 -->
  <view class="main-content">
    <!-- 左侧分类 -->
    <scroll-view class="category-sidebar" scroll-y scroll-into-view="{{scrollIntoCategory}}">
      <block wx:for="{{categories}}" wx:key="id">
        <view class="category-group-title {{activeCategoryGroup === item.id ? 'active' : ''}}" 
              data-id="{{item.id}}" 
              bindtap="onCategoryGroupTap">
          {{item.name}}
        </view>
        <block wx:if="{{activeCategoryGroup === item.id}}">
          <view wx:for="{{item.children}}" wx:for-item="child" wx:key="id"
                class="category-item {{activeCategory === child.id ? 'active' : ''}}"
                data-id="{{child.id}}"
                data-parent-id="{{item.id}}"
                bindtap="onCategoryTap">
            {{child.name}}
          </view>
        </block>
      </block>
    </scroll-view>

    <!-- 右侧商品列表 -->
    <scroll-view class="product-list" scroll-y scroll-into-view="{{scrollIntoProduct}}" scroll-with-animation="{{true}}" bindscroll="onProductScroll">
      <!-- 轮播banner -->
      <view wx:if="{{showBanner && banners.length > 0}}" class="banner-wrap">
        <swiper class="banner-swiper" indicator-dots autoplay circular interval="{{3000}}" indicator-color="rgba(255,255,255,0.5)" indicator-active-color="#fff">
          <swiper-item wx:for="{{banners}}" wx:key="id">
            <image class="banner-image" src="{{item.image}}" mode="aspectFill" />
            <view class="banner-title">{{item.title}}</view>
          </swiper-item>
        </swiper>
      </view>

      <block wx:for="{{productGroups}}" wx:key="categoryId">
        <view id="cate-{{item.categoryId}}" class="product-group">
          <view class="product-group-title">{{item.categoryName}}</view>
          <view wx:for="{{item.products}}" wx:for-item="product" wx:key="id" class="product-card">
            <image class="product-image" src="{{product.image}}" mode="aspectFill" data-id="{{product.id}}" bindtap="goToDetail" />
            <view class="product-info">
              <view class="product-name" data-id="{{product.id}}" bindtap="goToDetail">{{product.name}}</view>
              <!-- 标签 -->
              <view wx:if="{{product.tags && product.tags.length > 0}}" class="product-tags">
                <text wx:for="{{product.tags}}" wx:for-item="tag" wx:key="*this" class="product-tag">{{tag}}</text>
              </view>
              <view class="product-meta">
                <text wx:if="{{product.buyers > 0}}">{{product.buyers}}人已买</text>
                <text class="meta-dot" wx:if="{{product.buyers > 0 && product.followers > 0}}">·</text>
                <text wx:if="{{product.followers > 0}}">{{product.followers}}人关注</text>
              </view>
              <view class="product-price-row">
                <view class="product-price">¥{{product.priceText}}<text wx:if="{{product.unit}}">/{{product.unit}}</text></view>
                <view wx:if="{{product.originalPriceText}}" class="product-original-price">¥{{product.originalPriceText}}</view>
              </view>
              <view class="product-actions">
                <!-- 有规格的商品 -->
                <view wx:if="{{product.hasSpecs}}" class="spec-btn" data-product="{{product}}" bindtap="onSelectSpec">
                  选规格
                </view>
                <!-- 已售罄 -->
                <view wx:elif="{{product.stock <= 0}}" class="soldout-btn">
                  已售罄
                </view>
                <!-- 普通加减 -->
                <view wx:else class="quantity-control">
                  <view wx:if="{{product.cartQuantity > 0}}" class="qty-btn minus" data-id="{{product.id}}" catchtap="onMinus">−</view>
                  <view wx:if="{{product.cartQuantity > 0}}" class="qty-value">{{product.cartQuantity}}</view>
                  <view class="qty-btn plus" data-id="{{product.id}}" catchtap="onPlus">+</view>
                </view>
              </view>
            </view>
          </view>
        </view>
      </block>
      <!-- 底部占位 -->
      <view style="height: 200rpx;"></view>
    </scroll-view>
  </view>

  <!-- 底部购物车栏 -->
  <view class="cart-bar">
    <!-- 地址提示 -->
    <view class="address-tip" bindtap="goToAddress">
      <text class="address-icon">📍</text>
      <text wx:if="{{selectedAddress}}">{{selectedAddress.district}} {{selectedAddress.detail}}</text>
      <text wx:else class="no-address-text">请选择收货地址</text>
      <text class="arrow">›</text>
    </view>
    <view class="cart-bar-content">
      <view class="cart-icon-wrap" bindtap="goToCart">
        <image class="cart-icon" src="/images/cart.png" mode="aspectFit" />
        <view wx:if="{{cartTotalCount > 0}}" class="cart-badge">{{cartTotalCount > 99 ? '99+' : cartTotalCount}}</view>
      </view>
      <view class="cart-summary">
        <view class="cart-total">
          <text wx:if="{{cartTotalCount > 0}}">¥{{cartTotalPriceText}}</text>
          <text wx:else class="cart-empty-text">购物车是空的</text>
        </view>
        <view wx:if="{{cartTotalCount > 0}}" class="cart-count">共{{cartTotalCount}}件商品</view>
        <view wx:if="{{selectedAddress && cartTotalCount > 0}}" class="cart-delivery">预估配送费: ¥10.00</view>
      </view>
      <view class="checkout-btn {{cartTotalCount > 0 ? 'active' : ''}}" bindtap="onCheckout">
        <text wx:if="{{cartTotalCount > 0}}">去结算</text>
        <text wx:else>选好了</text>
      </view>
    </view>
  </view>

  <!-- 规格选择弹窗 -->
  <view wx:if="{{showSpecModal}}" class="spec-modal-mask" bindtap="closeSpecModal">
    <view class="spec-modal" catchtap="preventBubble">
      <view class="spec-modal-header">
        <image class="spec-product-image" src="{{specProduct.image}}" mode="aspectFill" />
        <view class="spec-product-info">
          <view class="spec-product-name">{{specProduct.name}}</view>
          <view class="spec-product-price">¥{{selectedSpecPrice}}</view>
        </view>
        <view class="spec-close" bindtap="closeSpecModal">×</view>
      </view>
      <view class="spec-list">
        <view class="spec-label">规格</view>
        <view class="spec-options">
          <view wx:for="{{specProduct.specs}}" wx:key="id"
                class="spec-option {{selectedSpecId === item.id ? 'active' : ''}}"
                data-spec="{{item}}"
                bindtap="onSpecSelect">
            {{item.name}}
          </view>
        </view>
      </view>
      <view class="spec-quantity-row">
        <text>数量</text>
        <view class="quantity-control">
          <view class="qty-btn minus" bindtap="onSpecMinus">−</view>
          <view class="qty-value">{{specQuantity}}</view>
          <view class="qty-btn plus" bindtap="onSpecPlus">+</view>
        </view>
      </view>
      <view class="spec-confirm-btn" bindtap="onSpecConfirm">加入购物车</view>
    </view>
  </view>
</view>