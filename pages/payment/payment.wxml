<view class="container">
  <!-- 收货地址 -->
  <view class="section address-section" bindtap="selectAddress">
    <view wx:if="{{address}}" class="address-info">
      <view class="address-header">
        <text class="address-name">{{address.name}}</text>
        <text class="address-phone">{{address.phone}}</text>
      </view>
      <view class="address-detail">{{address.province}} {{address.city}} {{address.district}} {{address.detail}}</view>
    </view>
    <view wx:else class="no-address">
      <text>请选择收货地址</text>
    </view>
    <text class="arrow">›</text>
  </view>

  <!-- 配送方式 -->
  <view class="section">
    <view class="section-title">配送方式</view>
    <view class="delivery-options">
      <view class="delivery-option {{deliveryType === 'express' ? 'active' : ''}}" 
            data-type="express" bindtap="selectDelivery">
        <text class="delivery-icon">🚚</text>
        <text>外送配送</text>
        <text class="delivery-fee">配送费 ¥{{deliveryFee}}</text>
      </view>
      <view class="delivery-option {{deliveryType === 'pickup' ? 'active' : ''}}" 
            data-type="pickup" bindtap="selectDelivery">
        <text class="delivery-icon">🏪</text>
        <text>到店自提</text>
        <text class="delivery-fee">免配送费</text>
      </view>
    </view>
  </view>

  <!-- 商品列表 -->
  <view class="section">
    <view class="section-title">商品清单</view>
    <view class="order-item" wx:for="{{items}}" wx:key="key">
      <image class="order-item-image" src="{{item.image}}" mode="aspectFill" />
      <view class="order-item-info">
        <view class="order-item-name">{{item.name}}</view>
        <view wx:if="{{item.specName}}" class="order-item-spec">{{item.specName}}</view>
        <view class="order-item-bottom">
          <text class="order-item-price">¥{{item.priceText}}</text>
          <text class="order-item-qty">×{{item.quantity}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 备注 -->
  <view class="section">
    <view class="section-title">订单备注</view>
    <textarea class="remark-input" placeholder="选填，请输入备注信息" value="{{remark}}" bindinput="onRemarkInput" />
  </view>

  <!-- 支付方式 -->
  <view class="section">
    <view class="section-title">支付方式</view>
    <view class="payment-options">
      <view class="payment-option {{paymentMethod === 'wechat' ? 'active' : ''}}" 
            data-method="wechat" bindtap="selectPayment">
        <image class="payment-icon" src="/images/wechat-pay.png" mode="aspectFit" />
        <text>微信支付</text>
        <view class="radio {{paymentMethod === 'wechat' ? 'checked' : ''}}">
          <text wx:if="{{paymentMethod === 'wechat'}}">✓</text>
        </view>
      </view>
      <view class="payment-option {{paymentMethod === 'alipay' ? 'active' : ''}}" 
            data-method="alipay" bindtap="selectPayment">
        <image class="payment-icon" src="/images/alipay.png" mode="aspectFit" />
        <text>支付宝</text>
        <view class="radio {{paymentMethod === 'alipay' ? 'checked' : ''}}">
          <text wx:if="{{paymentMethod === 'alipay'}}">✓</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 价格汇总 -->
  <view class="section price-summary">
    <view class="price-row">
      <text>商品金额</text>
      <text>¥{{goodsTotalText}}</text>
    </view>
    <view class="price-row">
      <text>配送费</text>
      <text>¥{{deliveryFeeText}}</text>
    </view>
    <view class="price-row total-row">
      <text>合计</text>
      <text class="total-price">¥{{totalPriceText}}</text>
    </view>
  </view>

  <!-- 底部提交 -->
  <view class="submit-bar">
    <view class="submit-total">
      <text>实付金额: </text>
      <text class="submit-price">¥{{totalPriceText}}</text>
    </view>
    <view class="submit-btn" bindtap="onSubmit">提交订单</view>
  </view>
</view>