.container {
  background: #f5f5f5;
  min-height: 100vh;
}

.status-bar {
  padding: 40rpx 32rpx;
  color: #fff;
}

.status-bar.paid {
  background: linear-gradient(135deg, #f5a623, #f7b731);
}

.status-bar.shipped {
  background: linear-gradient(135deg, #4A90D9, #5fa8e8);
}

.status-bar.completed {
  background: linear-gradient(135deg, #27ae60, #2ecc71);
}

.status-text {
  font-size: 36rpx;
  font-weight: bold;
  display: block;
  margin-bottom: 8rpx;
}

.status-desc {
  font-size: 26rpx;
  opacity: 0.9;
}

.section {
  background: #fff;
  margin: 16rpx;
  border-radius: 16rpx;
  padding: 24rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: bold;
  margin-bottom: 16rpx;
  color: #333;
}

.address-info {
  font-size: 26rpx;
  color: #333;
  line-height: 1.6;
}

.address-detail {
  display: block;
  color: #666;
  margin-top: 4rpx;
}

.order-item {
  display: flex;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.order-item:last-child {
  border-bottom: none;
}

.item-image {
  width: 120rpx;
  height: 120rpx;
  border-radius: 8rpx;
  flex-shrink: 0;
}

.item-info {
  flex: 1;
  margin-left: 16rpx;
}

.item-name {
  font-size: 28rpx;
  font-weight: bold;
  margin-bottom: 6rpx;
}

.item-spec {
  font-size: 22rpx;
  color: #999;
  background: #f5f5f5;
  padding: 4rpx 12rpx;
  border-radius: 4rpx;
  display: inline-block;
  margin-bottom: 8rpx;
}

.item-bottom {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.item-price {
  font-size: 28rpx;
  color: #e74c3c;
  font-weight: bold;
}

.item-qty {
  font-size: 24rpx;
  color: #999;
}

.info-row {
  display: flex;
  justify-content: space-between;
  padding: 10rpx 0;
  font-size: 26rpx;
}

.info-label {
  color: #999;
}

.info-value {
  color: #333;
}

.price-row {
  display: flex;
  justify-content: space-between;
  padding: 10rpx 0;
  font-size: 26rpx;
  color: #666;
}

.price-row.total {
  border-top: 1rpx solid #f0f0f0;
  padding-top: 16rpx;
  margin-top: 8rpx;
  font-weight: bold;
  color: #333;
}

.total-amount {
  color: #e74c3c;
  font-size: 34rpx;
}