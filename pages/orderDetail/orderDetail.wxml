<view class="container">
  <!-- 订单状态 -->
  <view class="status-bar {{order.status}}">
    <text class="status-text">{{order.statusText}}</text>
    <text class="status-desc" wx:if="{{order.status === 'paid'}}">商家正在准备商品</text>
    <text class="status-desc" wx:if="{{order.status === 'shipped'}}">商品正在配送中</text>
    <text class="status-desc" wx:if="{{order.status === 'completed'}}">订单已完成，感谢您的购买</text>
  </view>

  <!-- 收货地址 -->
  <view wx:if="{{order.address}}" class="section">
    <view class="section-title">收货信息</view>
    <view class="address-info">
      <text>{{order.address.name}} {{order.address.phone}}</text>
      <text class="address-detail">{{order.address.province}} {{order.address.city}} {{order.address.district}} {{order.address.detail}}</text>
    </view>
  </view>

  <!-- 商品列表 -->
  <view class="section">
    <view class="section-title">商品信息</view>
    <view class="order-item" wx:for="{{order.items}}" wx:key="key">
      <image class="item-image" src="{{item.image}}" mode="aspectFill" />
      <view class="item-info">
        <view class="item-name">{{item.name}}</view>
        <view wx:if="{{item.specName}}" class="item-spec">{{item.specName}}</view>
        <view class="item-bottom">
          <text class="item-price">¥{{item.priceText}}</text>
          <text class="item-qty">×{{item.quantity}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 订单信息 -->
  <view class="section">
    <view class="section-title">订单信息</view>
    <view class="info-row">
      <text class="info-label">订单编号</text>
      <text class="info-value">{{order.orderNo}}</text>
    </view>
    <view class="info-row">
      <text class="info-label">下单时间</text>
      <text class="info-value">{{order.createTime}}</text>
    </view>
    <view class="info-row">
      <text class="info-label">配送方式</text>
      <text class="info-value">{{order.deliveryType === 'express' ? '外送配送' : '到店自提'}}</text>
    </view>
    <view class="info-row">
      <text class="info-label">支付方式</text>
      <text class="info-value">{{order.paymentMethod === 'wechat' ? '微信支付' : '支付宝'}}</text>
    </view>
    <view wx:if="{{order.remark}}" class="info-row">
      <text class="info-label">备注</text>
      <text class="info-value">{{order.remark}}</text>
    </view>
  </view>

  <!-- 价格汇总 -->
  <view class="section">
    <view class="price-row">
      <text>商品金额</text>
      <text>¥{{order.goodsTotalText}}</text>
    </view>
    <view class="price-row">
      <text>配送费</text>
      <text>¥{{order.deliveryFeeText}}</text>
    </view>
    <view class="price-row total">
      <text>实付金额</text>
      <text class="total-amount">¥{{order.totalPriceText}}</text>
    </view>
  </view>
</view>